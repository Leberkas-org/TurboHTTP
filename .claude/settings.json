{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "slopwatch analyze -d $(git rev-parse --show-toplevel) --hook",
            "timeout": 60000
          }
        ]
      }
    ]
  }
}
