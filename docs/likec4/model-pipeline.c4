// TurboHTTP — Pipeline Flow Relationships (Client & Server)
// Extends model.c4 with ordered flow and feedback relationships
// for both client and server request processing pipelines.
//
// CLIENT PIPELINE STACKING (outermost -> innermost):
//   Handler -> Tracing -> Redirect -> Cookie -> Retry -> Expect100 -> Cache -> ContentEncoding -> AltSvc -> Engine
//
// CLIENT REQUEST CHAIN (app -> Network):
//   enricher -> handler -> tracing -> redirect -> cookie -> retry -> expect100 -> cache -> contentEncoding
//   -> altSvc -> engine -> [version engines -> Network]
//
// CLIENT RESPONSE CHAIN (Network -> app):
//   engine -> altSvc -> contentEncoding -> cache -> expect100 -> retry -> cookie -> redirect -> tracing -> handler -> app
//
// CLIENT FEEDBACK LOOPS
//   redirect   --- redirect request -->  cookie (re-enters with cookie injection for new URL)
//   retry      --- retry request    -->  expect100 (re-enters below cookie, above engine)
//   cache hit  --- cached response  -->  response chain at retry level (bypasses ContentEncoding + engine)
//
// SERVER PIPELINE (per connection, inside ConnectionActor):
//   Network -> ConnectionStage -> ApplicationBridgeStage -> IHttpApplication<TContext> (ASP.NET Core)
//   Response flows back through the same IFeatureCollection.

model {
  // Request chain (outermost -> innermost)
  turbohttp.client.TurboHttpClient -[flows]-> turbohttp.streams.RequestEnricher 'request'
  turbohttp.streams.RequestEnricher -[flows]-> turbohttp.streams.HandlerBidiStage 'request (defaults applied)'
  turbohttp.streams.HandlerBidiStage -[flows]-> turbohttp.streams.TracingBidiStage 'request'
  turbohttp.streams.TracingBidiStage -[flows]-> turbohttp.streams.RedirectBidiStage 'request'
  turbohttp.streams.RedirectBidiStage -[flows]-> turbohttp.streams.CookieBidiStage 'request'
  turbohttp.streams.CookieBidiStage -[flows]-> turbohttp.streams.RetryBidiStage 'request (cookies injected)'
  turbohttp.streams.RetryBidiStage -[flows]-> turbohttp.streams.ExpectContinueBidiStage 'request'
  turbohttp.streams.ExpectContinueBidiStage -[flows]-> turbohttp.streams.CacheBidiStage 'request'
  turbohttp.streams.CacheBidiStage -[flows]-> turbohttp.streams.ContentEncodingBidiStage 'request (cache miss)'
  turbohttp.streams.ContentEncodingBidiStage -[flows]-> turbohttp.streams.AltSvcBidiStage 'request (body compressed)'
  turbohttp.streams.AltSvcBidiStage -[flows]-> turbohttp.streams.Engine 'request (version resolved)'

  // Engine dispatch
  turbohttp.streams.Engine -[flows]-> turbohttp.streams.Http10ClientEngine 'HTTP/1.0'
  turbohttp.streams.Engine -[flows]-> turbohttp.streams.Http11ClientEngine 'HTTP/1.1'
  turbohttp.streams.Engine -[flows]-> turbohttp.streams.Http20ClientEngine 'HTTP/2'
  turbohttp.streams.Engine -[flows]-> turbohttp.streams.Http30ClientEngine 'HTTP/3'

  // HTTP/1.0: Engine -> ConnectionStage -> Transport
  turbohttp.streams.Http10ClientEngine -[flows]-> turbohttp.streams.Http10ClientConnectionStage 'request'
  turbohttp.streams.Http10ClientConnectionStage -[flows]-> servus.TcpConnectionStage 'outbound bytes'
  servus.TcpConnectionStage -[flows]-> turbohttp.streams.Http10ClientConnectionStage 'inbound bytes'
  turbohttp.streams.Http10ClientConnectionStage -[flows]-> turbohttp.streams.ContentEncodingBidiStage 'response'

  // HTTP/1.1: Engine -> ConnectionStage -> Transport
  turbohttp.streams.Http11ClientEngine -[flows]-> turbohttp.streams.Http11ClientConnectionStage 'request'
  turbohttp.streams.Http11ClientConnectionStage -[flows]-> servus.TcpConnectionStage 'outbound bytes'
  servus.TcpConnectionStage -[flows]-> turbohttp.streams.Http11ClientConnectionStage 'inbound bytes'
  turbohttp.streams.Http11ClientConnectionStage -[flows]-> turbohttp.streams.ContentEncodingBidiStage 'response'

  // HTTP/2: Engine -> ConnectionStage -> Transport
  turbohttp.streams.Http20ClientEngine -[flows]-> turbohttp.streams.Http20ClientConnectionStage 'request'
  turbohttp.streams.Http20ClientConnectionStage -[flows]-> servus.TcpConnectionStage 'outbound bytes'
  servus.TcpConnectionStage -[flows]-> turbohttp.streams.Http20ClientConnectionStage 'inbound bytes'
  turbohttp.streams.Http20ClientConnectionStage -[flows]-> turbohttp.streams.ContentEncodingBidiStage 'response'

  // HTTP/3: Engine -> ConnectionStage -> Transport
  turbohttp.streams.Http30ClientEngine -[flows]-> turbohttp.streams.Http30ClientConnectionStage 'request'
  turbohttp.streams.Http30ClientConnectionStage -[flows]-> servus.QuicConnectionStage 'outbound bytes'
  servus.QuicConnectionStage -[flows]-> turbohttp.streams.Http30ClientConnectionStage 'inbound bytes'
  turbohttp.streams.Http30ClientConnectionStage -[flows]-> turbohttp.streams.ContentEncodingBidiStage 'response'

  // Transport -> Network
  servus.TcpConnectionStage -[flows]-> servus.TcpConnectionManagerActor 'connection lease'
  servus.TcpConnectionManagerActor -[flows]-> servus.TcpConnectionStage 'connection ready'
  servus.TcpConnectionStage -[flows]-> network 'TCP/TLS bytes'
  network -[flows]-> servus.TcpConnectionStage 'TCP/TLS bytes'

  servus.QuicConnectionStage -[flows]-> servus.QuicConnectionManagerActor 'connection lease'
  servus.QuicConnectionManagerActor -[flows]-> servus.QuicConnectionStage 'connection ready'
  servus.QuicConnectionStage -[flows]-> network 'QUIC bytes'
  network -[flows]-> servus.QuicConnectionStage 'QUIC bytes'

  // Response chain (innermost -> outermost)
  turbohttp.streams.ContentEncodingBidiStage -[flows]-> turbohttp.streams.CacheBidiStage 'response (decompressed)'
  turbohttp.streams.CacheBidiStage -[flows]-> turbohttp.streams.ExpectContinueBidiStage 'response (stored if cacheable)'
  turbohttp.streams.ExpectContinueBidiStage -[flows]-> turbohttp.streams.RetryBidiStage 'response'
  turbohttp.streams.RetryBidiStage -[flows]-> turbohttp.streams.CookieBidiStage 'response'
  turbohttp.streams.CookieBidiStage -[flows]-> turbohttp.streams.RedirectBidiStage 'response (cookies stored)'
  turbohttp.streams.RedirectBidiStage -[flows]-> turbohttp.streams.TracingBidiStage 'response'
  turbohttp.streams.TracingBidiStage -[flows]-> turbohttp.streams.HandlerBidiStage 'response (traced)'
  turbohttp.streams.HandlerBidiStage -[flows]-> turbohttp.client.TurboHttpClient 'response'

  // Feedback: cache hit bypasses engine, re-enters at Retry
  turbohttp.streams.CacheBidiStage -[feedback]-> turbohttp.streams.RetryBidiStage 'cached response (bypasses network)'

  // Feedback: redirect re-enters at Cookie (new URL needs cookie injection)
  turbohttp.streams.RedirectBidiStage -[feedback]-> turbohttp.streams.CookieBidiStage 'redirect (re-enters at cookies)'

  // Feedback: retry re-enters at ExpectContinue (same URL, cookies already set)
  turbohttp.streams.RetryBidiStage -[feedback]-> turbohttp.streams.ExpectContinueBidiStage 'retry (re-enters below cookies)'

  // ─── Server: Inbound — Network → ConnectionStage (wire decode) ────

  network -[flows]-> turbohttp.serverStages.Http10ServerConnectionStage 'inbound bytes'
  network -[flows]-> turbohttp.serverStages.Http11ServerConnectionStage 'inbound bytes'
  network -[flows]-> turbohttp.serverStages.Http20ServerConnectionStage 'inbound bytes'
  network -[flows]-> turbohttp.serverStages.Http30ServerConnectionStage 'inbound bytes'

  // ─── Server: ConnectionStage → ApplicationBridgeStage (decoded request as IFeatureCollection)

  turbohttp.serverStages.Http10ServerConnectionStage -[flows]-> turbohttp.serverStages.ApplicationBridgeStage 'IFeatureCollection'
  turbohttp.serverStages.Http11ServerConnectionStage -[flows]-> turbohttp.serverStages.ApplicationBridgeStage 'IFeatureCollection'
  turbohttp.serverStages.Http20ServerConnectionStage -[flows]-> turbohttp.serverStages.ApplicationBridgeStage 'IFeatureCollection'
  turbohttp.serverStages.Http30ServerConnectionStage -[flows]-> turbohttp.serverStages.ApplicationBridgeStage 'IFeatureCollection'

  // ─── Server: ApplicationBridgeStage dispatches to ASP.NET Core ────
  // ApplicationBridgeStage calls IHttpApplication.CreateContext(features) → ProcessRequestAsync() → DisposeContext()

  // ─── Server: Response — ApplicationBridgeStage → ConnectionStage → Network

  turbohttp.serverStages.ApplicationBridgeStage -[flows]-> turbohttp.serverStages.Http10ServerConnectionStage 'response IFeatureCollection'
  turbohttp.serverStages.ApplicationBridgeStage -[flows]-> turbohttp.serverStages.Http11ServerConnectionStage 'response IFeatureCollection'
  turbohttp.serverStages.ApplicationBridgeStage -[flows]-> turbohttp.serverStages.Http20ServerConnectionStage 'response IFeatureCollection'
  turbohttp.serverStages.ApplicationBridgeStage -[flows]-> turbohttp.serverStages.Http30ServerConnectionStage 'response IFeatureCollection'

  // ─── Server: Outbound — ConnectionStage → Network (wire encode) ───

  turbohttp.serverStages.Http10ServerConnectionStage -[flows]-> network 'outbound bytes'
  turbohttp.serverStages.Http11ServerConnectionStage -[flows]-> network 'outbound bytes'
  turbohttp.serverStages.Http20ServerConnectionStage -[flows]-> network 'outbound bytes'
  turbohttp.serverStages.Http30ServerConnectionStage -[flows]-> network 'outbound bytes'
}
