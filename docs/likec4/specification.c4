// TurboHTTP — Specification
// Element kinds, tags, and custom relationship types shared across all views.

specification {
  element person {
    style {
      shape person
      color primary
    }
  }

  element system {
    style {
      color green
    }
  }

  element externalSystem {
    style {
      color muted
    }
  }

  element container {
    style {
      color blue
    }
  }

  element component {
    style {
      color sky
    }
  }

  element actor {
    style {
      color amber
    }
  }

  // Tags for visual grouping
  tag stage
  tag server
  tag http2
  tag http3
  tag cache
  tag cookie
  tag redirect
  tag retry
  tag api

  // flows    — ordered pipeline data flow (request chain or response chain)
  // feedback — cycle-back path (retry / redirect / cache-hit bypass)
  // delegates — stage delegates to a stateless protocol helper

  relationship flows {
    color green
  }

  relationship feedback {
    color red
    line dashed
  }

  relationship delegates {
    color secondary
    line dotted
  }
}
